#!/usr/bin/env bash

shopt -s nullglob dotglob

THIS="$(realpath "$0" 2>/dev/null || command -v "$0")"
PORTABLES="$(dirname "$THIS")"
PORTABLE_HOME="$PORTABLES/home"
HOME=${HOME:-~}
OS="${OS:-$(uname -s)}"
LINK_CONFLICT_MODE="${LINK_CONFLICT_MODE:-skip}"
BACKUP_STAMP="$(date +%Y%m%d%H%M%S)"

LOG_NAME="${LOG_NAME:+$LOG_NAME.}${THIS##*/}"
functions log >/dev/null 2>&1 || . "$PORTABLES"/log

if [[ -n "${HOST-}" ]]; then
  MACHINE=${HOST%%.*}
else
  MACHINE=$(hostname 2>/dev/null) || MACHINE=mystery-box
  MACHINE=${MACHINE%%.*}
fi

link_file() {
  local source_path="$1"
  local destination="$2"
  local parent_dir
  local linked_target

  parent_dir="$(dirname "$destination")"
  if [[ -e "$parent_dir" ]] && [[ ! -d "$parent_dir" ]]; then
    log -w "cannot link into non-directory path: $parent_dir"
    return 1
  fi

  mkdir -p "$parent_dir"

  if [[ -L "$destination" ]]; then
    linked_target="$(readlink "$destination")"
    if [[ "$linked_target" = "$source_path" ]]; then
      log -d "already linked $source_path -> $destination"
      return 0
    fi
  fi

  if [[ -e "$destination" ]] || [[ -L "$destination" ]]; then
    case "$LINK_CONFLICT_MODE" in
    force)
      rm -rf "$destination"
      ;;
    backup)
      mv "$destination" "${destination}.bak.${BACKUP_STAMP}"
      log -i "backed up $destination -> ${destination}.bak.${BACKUP_STAMP}"
      ;;
    skip)
      log -w "skipping existing path: $destination"
      return 0
      ;;
    *)
      log -w "unknown LINK_CONFLICT_MODE=$LINK_CONFLICT_MODE; skipping $destination"
      return 0
      ;;
    esac
  fi

  ln -s "$source_path" "$destination" &&
    log -d "linked $source_path -> $destination"
}

path_is_within() {
  local path="$1"
  local root="$2"

  case "$path" in
  "$root" | "$root"/*) return 0 ;;
  *) return 1 ;;
  esac
}

source_dir_is_pruned() {
  local source_root="$1"
  local source_path="$2"
  local relative_path

  if [[ "$source_root" != "$PORTABLE_HOME" || "$OS" = Darwin ]]; then
    return 1
  fi

  relative_path="${source_path#$source_root/}"
  [[ "$relative_path" = "Library" ]]
}

ACTIVE_SOURCE_DIRS=$'\n'

source_dir_active() {
  local resolved_path="$1"
  case "$ACTIVE_SOURCE_DIRS" in
  *$'\n'"$resolved_path"$'\n'*) return 0 ;;
  *) return 1 ;;
  esac
}

mark_source_dir_active() {
  local resolved_path="$1"
  ACTIVE_SOURCE_DIRS+="$resolved_path"$'\n'
}

clear_source_dir_active() {
  local resolved_path="$1"
  ACTIVE_SOURCE_DIRS="${ACTIVE_SOURCE_DIRS%"$resolved_path"$'\n'}"
}

link_tree_directory() {
  local current_path="$1"
  local source_root="$2"
  local destination_root="$3"
  local resolved_current_path
  local source_path
  local resolved_source_path
  local relative_path
  local destination_path

  [[ -d "$current_path" ]] || return 0

  resolved_current_path="$(realpath "$current_path" 2>/dev/null)" || return 0
  [[ -d "$resolved_current_path" ]] || return 0

  if source_dir_active "$resolved_current_path"; then
    return 0
  fi
  mark_source_dir_active "$resolved_current_path"

  for source_path in "$current_path"/*; do
    [[ -e "$source_path" || -L "$source_path" ]] || continue

    relative_path="${source_path#$source_root/}"
    destination_path="$destination_root/$relative_path"

    if source_dir_is_pruned "$source_root" "$source_path"; then
      continue
    fi

    if [[ -L "$source_path" && -d "$source_path" ]]; then
      resolved_source_path="$(realpath "$source_path" 2>/dev/null)" || continue
      if path_is_within "$resolved_source_path" "$PORTABLE_HOME"; then
        link_tree_directory "$source_path" "$source_root" "$destination_root"
      else
        link_file "$source_path" "$destination_path"
      fi
    elif [[ -d "$source_path" ]]; then
      link_tree_directory "$source_path" "$source_root" "$destination_root"
    elif [[ -f "$source_path" || -L "$source_path" ]]; then
      link_file "$source_path" "$destination_path"
    fi
  done

  clear_source_dir_active "$resolved_current_path"
}

link_tree_files() {
  local source_root="$1"
  local destination_root="$2"

  [[ -d "$source_root" ]] || return 0
  link_tree_directory "$source_root" "$source_root" "$destination_root"
}

link_relative_path() {
  local relative_path="${1:-}"
  local source_path
  local destination

  [[ "$relative_path" = "." ]] && relative_path=
  source_path="${PORTABLE_HOME}${relative_path:+/$relative_path}"
  destination="${HOME}${relative_path:+/$relative_path}"

  if [[ -f "$source_path" ]]; then
    link_file "$source_path" "$destination"
  elif [[ -d "$source_path" ]]; then
    link_tree_files "$source_path" "$destination"
  else
    log -w "nothing to link for $relative_path"
  fi
}

if [[ $# -gt 0 ]]; then
  log "symlinking ${*}…"
  for fn in "$@"; do
    link_relative_path "$fn"
  done
else
  log "establishing symlinks…"
  link_relative_path
fi

log "symlinking complete."

shopt -u nullglob dotglob
