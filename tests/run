#!/usr/bin/env bash

set -euo pipefail

TESTS_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "$TESTS_DIR/.." && pwd)"

export TESTS_DIR REPO_ROOT

. "$TESTS_DIR/lib/harness.bash"

if [[ $# -gt 0 ]]; then
  test_files=( "$@" )
else
  shopt -s nullglob
  test_files=( "$TESTS_DIR"/*_test.bash )
  shopt -u nullglob
fi

if [[ ${#test_files[@]} -eq 0 ]]; then
  printf 'no test files found\n' >&2
  exit 1
fi

for test_file in "${test_files[@]}"; do
  . "$test_file"
done

finish_tests
