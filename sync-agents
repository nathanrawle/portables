#!/usr/bin/env python3
"""Synchronize Claude, Codex, and Copilot agent definitions."""

from __future__ import annotations

import argparse
import json
import re
import sys
import tomllib
from dataclasses import dataclass
from pathlib import Path
from typing import Any


READ_ONLY_TOOLS = ["Read", "Glob", "Grep", "Bash"]
WRITE_TOOLS = ["Read", "Glob", "Grep", "Edit", "Write", "Bash"]
COPILOT_READ_ONLY_TOOLS = ["read", "search"]
COPILOT_WRITE_TOOLS = ["read", "search", "edit", "shell"]
PROVIDERS = ("claude", "copilot", "codex")
SOURCE_PREFERENCE = {
    "claude": ("copilot", "codex"),
    "copilot": ("codex", "claude"),
    "codex": ("copilot", "claude"),
}
WRITE_TOOL_MARKERS = ("edit", "write", "run", "shell", "terminal")
OPENAI_MODEL_MARKERS = ("gpt", "chatgpt", "o1", "o3", "o4")


@dataclass(frozen=True)
class AgentFile:
    id: str
    path: Path


@dataclass(frozen=True)
class CreateAction:
    target: str
    id: str
    path: Path
    content: str


@dataclass(frozen=True)
class AgentSpec:
    id: str
    name: str
    description: str
    model: str
    model_reasoning_effort: str
    sandbox_mode: str
    instructions: str


def normalize_id(path: Path) -> str:
    name = path.name
    for suffix in (".toml", ".md"):
        if name.endswith(suffix):
            name = name[: -len(suffix)]
            break
    if name.endswith(".agent"):
        name = name[: -len(".agent")]
    return name


def discover_agents(directory: Path, suffix: str) -> dict[str, AgentFile]:
    agents: dict[str, AgentFile] = {}
    if not directory.is_dir():
        return agents
    for path in sorted(directory.iterdir()):
        if not path.is_file() or path.name.startswith(".") or path.suffix != suffix:
            continue
        agent_id = normalize_id(path)
        agents.setdefault(agent_id, AgentFile(agent_id, path))
    return agents


def parse_frontmatter(text: str) -> tuple[dict[str, Any], str]:
    if not text.startswith("---\n"):
        return {}, text
    end = text.find("\n---\n", 4)
    if end == -1:
        return {}, text
    raw_frontmatter = text[4:end]
    body = text[end + len("\n---\n") :]
    return parse_simple_yaml(raw_frontmatter), body


def parse_simple_yaml(text: str) -> dict[str, Any]:
    data: dict[str, Any] = {}
    block_list_key = ""
    for raw_line in text.splitlines():
        stripped = raw_line.strip()
        if block_list_key and raw_line[:1].isspace() and stripped.startswith("- "):
            data[block_list_key].append(parse_yaml_value(stripped[2:].strip()))
            continue
        if not raw_line[:1].isspace():
            block_list_key = ""
        elif raw_line[:1].isspace():
            continue
        line = raw_line.strip()
        if not line or line.startswith("#") or ":" not in line:
            continue
        key, value = line.split(":", 1)
        key = key.strip()
        value = value.strip()
        if value == "":
            data[key] = []
            block_list_key = key
            continue
        data[key] = parse_yaml_value(value)
    return data


def parse_yaml_value(value: str) -> Any:
    if value == "":
        return ""
    if value.startswith("[") and value.endswith("]"):
        inner = value[1:-1].strip()
        if not inner:
            return []
        return [parse_yaml_value(part.strip()) for part in split_csv(inner)]
    if (value.startswith("'") and value.endswith("'")) or (
        value.startswith('"') and value.endswith('"')
    ):
        return value[1:-1]
    return value


def split_csv(text: str) -> list[str]:
    parts: list[str] = []
    current: list[str] = []
    quote = ""
    for char in text:
        if quote:
            current.append(char)
            if char == quote:
                quote = ""
        elif char in ("'", '"'):
            quote = char
            current.append(char)
        elif char == ",":
            parts.append("".join(current))
            current = []
        else:
            current.append(char)
    parts.append("".join(current))
    return parts


def scalar(data: dict[str, Any], key: str, default: str = "") -> str:
    value = data.get(key, default)
    if value is None:
        return default
    if isinstance(value, str):
        return value
    return str(value)


def list_value(data: dict[str, Any], key: str) -> list[str]:
    value = data.get(key, [])
    if isinstance(value, list):
        return [str(item) for item in value]
    if isinstance(value, str):
        return [value]
    return []


def claude_effort_and_model(model: str) -> tuple[str, str]:
    model = model.lower()
    if "opus" in model:
        return "xhigh", ""
    if "haiku" in model:
        return "medium", "gpt-5.4-mini"
    if "sonnet" in model:
        return "high", "gpt-5.4-mini"
    return "high", "gpt-5.4-mini"


def codex_to_claude_model(model: str, effort: str) -> str:
    model = model.lower()
    effort = effort.lower()
    is_mini = "mini" in model
    if is_mini and effort in {"low", "medium"}:
        return "haiku"
    if is_mini and effort == "high":
        return "sonnet"
    if not is_mini and effort in {"high", "xhigh"}:
        return "opus"
    return "sonnet"


def is_openai_model(model: str) -> bool:
    normalized = model.lower()
    return any(marker in normalized for marker in OPENAI_MODEL_MARKERS)


def model_effort(model: str, default: str = "high") -> str:
    normalized = model.lower()
    if "opus" in normalized or "xhigh" in normalized:
        return "xhigh"
    if "haiku" in normalized or "mini" in normalized or "medium" in normalized:
        return "medium"
    if "low" in normalized:
        return "low"
    if "gpt-5" in normalized or "high" in normalized or "sonnet" in normalized:
        return "high"
    return default


def tools_sandbox(tools: list[str]) -> str:
    normalized = [tool.lower() for tool in tools]
    if any(marker in tool for tool in normalized for marker in WRITE_TOOL_MARKERS):
        return "workspace-write"
    return "read-only"


def sandbox_is_writable(sandbox: str) -> bool:
    return sandbox != "read-only"


def toml_string(value: str) -> str:
    return json.dumps(value, ensure_ascii=False)


def parse_markdown_agent(path: Path, provider: str) -> AgentSpec:
    frontmatter, body = parse_frontmatter(path.read_text())
    agent_id = normalize_id(path)
    model = scalar(frontmatter, "model")
    tools = list_value(frontmatter, "tools")

    if provider == "claude":
        effort, codex_model = claude_effort_and_model(model)
        spec_model = codex_model
        sandbox = "workspace-write" if {"Edit", "Write"} & set(tools) else "read-only"
    else:
        effort = model_effort(model)
        if not model:
            spec_model = ""
        elif is_openai_model(model):
            spec_model = model
        else:
            spec_model = claude_effort_and_model(model)[1]
        sandbox = tools_sandbox(tools)

    return AgentSpec(
        id=agent_id,
        name=scalar(frontmatter, "name", agent_id),
        description=scalar(frontmatter, "description"),
        model=spec_model,
        model_reasoning_effort=effort,
        sandbox_mode=sandbox,
        instructions=body,
    )


def parse_codex_agent(path: Path) -> AgentSpec:
    try:
        data = tomllib.loads(path.read_text())
    except tomllib.TOMLDecodeError as exc:
        raise ValueError(f"failed to parse Codex agent {path}: {exc}") from exc
    agent_id = normalize_id(path)
    return AgentSpec(
        id=agent_id,
        name=scalar(data, "name", agent_id),
        description=scalar(data, "description"),
        model=scalar(data, "model"),
        model_reasoning_effort=scalar(data, "model_reasoning_effort"),
        sandbox_mode=scalar(data, "sandbox_mode"),
        instructions=scalar(data, "developer_instructions"),
    )


def parse_agent(agent: AgentFile, provider: str) -> AgentSpec:
    if provider == "codex":
        return parse_codex_agent(agent.path)
    return parse_markdown_agent(agent.path, provider)


def render_codex(spec: AgentSpec) -> str:
    lines = [
        f"name = {toml_string(spec.name)}",
        f"description = {toml_string(spec.description)}",
    ]
    if spec.model:
        lines.append(f"model = {toml_string(spec.model)}")
    lines.extend(
        [
            f"model_reasoning_effort = {toml_string(spec.model_reasoning_effort)}",
            f"sandbox_mode = {toml_string(spec.sandbox_mode)}",
            "",
            f"developer_instructions = {toml_string(spec.instructions)}",
            "",
        ]
    )
    return "\n".join(lines)


def render_claude(spec: AgentSpec) -> str:
    claude_model = codex_to_claude_model(spec.model, spec.model_reasoning_effort)
    tools = READ_ONLY_TOOLS if spec.sandbox_mode == "read-only" else WRITE_TOOLS

    frontmatter = [
        "---",
        f"name: {json.dumps(spec.name, ensure_ascii=False)}",
        f"description: {json.dumps(spec.description, ensure_ascii=False)}",
        f"model: {claude_model}",
        "tools: [" + ", ".join(json.dumps(tool) for tool in tools) + "]",
        "---",
        "",
    ]
    return "\n".join(frontmatter) + spec.instructions


def render_copilot(spec: AgentSpec) -> str:
    tools = COPILOT_WRITE_TOOLS if sandbox_is_writable(spec.sandbox_mode) else COPILOT_READ_ONLY_TOOLS
    frontmatter = [
        "---",
        f"name: {json.dumps(spec.name, ensure_ascii=False)}",
        f"description: {json.dumps(spec.description, ensure_ascii=False)}",
    ]
    if spec.model:
        frontmatter.append(f"model: {json.dumps(spec.model, ensure_ascii=False)}")
    frontmatter.extend(
        [
            "tools: [" + ", ".join(json.dumps(tool) for tool in tools) + "]",
            "---",
            "",
        ]
    )
    return "\n".join(frontmatter) + spec.instructions


def render_agent(spec: AgentSpec, provider: str) -> str:
    if provider == "claude":
        return render_claude(spec)
    if provider == "copilot":
        return render_copilot(spec)
    if provider == "codex":
        return render_codex(spec)
    raise ValueError(f"unknown provider: {provider}")


def load_registered_codex_agents(config_path: Path) -> set[str]:
    if not config_path.is_file():
        return set()
    text = config_path.read_text()
    return set(re.findall(r"(?m)^\[agents\.([^\]\s]+)\]\s*$", text))


def registration_block(agent_id: str) -> str:
    return f"[agents.{agent_id}]\nconfig_file = \"./agents/{agent_id}.toml\"\n"


def insert_agent_registrations(config_text: str, agent_ids: list[str]) -> str:
    if not agent_ids:
        return config_text

    addition = "\n\n".join(registration_block(agent_id).rstrip() for agent_id in agent_ids)
    addition = f"\n{addition}\n"
    lines = config_text.splitlines(keepends=True)
    agent_header = re.compile(r"^\[agents\.[^\]]+\]\s*$")
    table_header = re.compile(r"^\[[^\]]+\]\s*$")

    last_agent_index: int | None = None
    for index, line in enumerate(lines):
        if agent_header.match(line.strip()):
            last_agent_index = index

    if last_agent_index is None:
        if config_text and not config_text.endswith("\n"):
            return config_text + "\n" + addition
        return config_text + addition.lstrip("\n")

    insert_at = len(lines)
    for index in range(last_agent_index + 1, len(lines)):
        if table_header.match(lines[index].strip()):
            insert_at = index
            break

    before = "".join(lines[:insert_at]).rstrip() + "\n"
    after = "".join(lines[insert_at:]).lstrip("\n")
    if after:
        return before + addition + "\n" + after
    return before + addition


def plan_actions(root: Path) -> tuple[list[CreateAction], list[str]]:
    directories = {
        "claude": root / "home/.claude/agents",
        "copilot": root / "home/.copilot/agents",
        "codex": root / "home/.codex/agents",
    }
    suffixes = {
        "claude": ".md",
        "copilot": ".agent.md",
        "codex": ".toml",
    }
    discovery_suffixes = {
        "claude": ".md",
        "copilot": ".md",
        "codex": ".toml",
    }
    config_path = root / "home/.codex/config.toml"

    agents = {
        provider: discover_agents(directories[provider], discovery_suffixes[provider])
        for provider in PROVIDERS
    }
    all_ids = sorted(set().union(*(set(provider_agents) for provider_agents in agents.values())))

    creates: list[CreateAction] = []
    for agent_id in all_ids:
        for target in PROVIDERS:
            if agent_id in agents[target]:
                continue
            for source in SOURCE_PREFERENCE[target]:
                if agent_id not in agents[source]:
                    continue
                suffix = suffixes[target]
                target_path = directories[target] / f"{agent_id}{suffix}"
                spec = parse_agent(agents[source][agent_id], source)
                creates.append(
                    CreateAction(
                        target,
                        agent_id,
                        target_path,
                        render_agent(spec, target),
                    )
                )
                break

    registered = load_registered_codex_agents(config_path)
    codex_ids_after_sync = sorted(set(agents["codex"]) | {a.id for a in creates if a.target == "codex"})
    registrations = [agent_id for agent_id in codex_ids_after_sync if agent_id not in registered]
    return creates, registrations


def print_plan(creates: list[CreateAction], registrations: list[str]) -> None:
    for action in creates:
        print(f"create {action.target} {action.path}")
    for agent_id in registrations:
        print(f"register codex {agent_id}")


def apply_actions(root: Path, creates: list[CreateAction], registrations: list[str]) -> None:
    for action in creates:
        action.path.parent.mkdir(parents=True, exist_ok=True)
        action.path.write_text(action.content)

    if registrations:
        config_path = root / "home/.codex/config.toml"
        config_path.parent.mkdir(parents=True, exist_ok=True)
        config_text = config_path.read_text() if config_path.is_file() else ""
        config_path.write_text(insert_agent_registrations(config_text, registrations))


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument("--dry-run", action="store_true", help="print changes without writing")
    parser.add_argument("--check", action="store_true", help="exit non-zero if changes are needed")
    parser.add_argument(
        "--root",
        type=Path,
        default=Path(__file__).resolve().parent,
        help="repository root to synchronize",
    )
    args = parser.parse_args(argv)

    root = args.root.resolve()
    try:
        creates, registrations = plan_actions(root)
    except ValueError as exc:
        print(f"sync-agents: error: {exc}", file=sys.stderr)
        return 2
    changed = bool(creates or registrations)

    if args.dry_run or args.check:
        print_plan(creates, registrations)
    if args.check:
        return 1 if changed else 0
    if args.dry_run:
        return 0
    if changed:
        apply_actions(root, creates, registrations)
        print_plan(creates, registrations)
    else:
        print("sync-agents: no changes")
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
